# ═══════════════════════════════════════
# QShield CSOC Platform — .gitignore
# ═══════════════════════════════════════

# Java Build Output
target/
*.class

# IDE
.idea/
*.iml
.vscode/
.settings/
.project
.classpath
*.swp
*.swo

# Maven wrapper (kept in repo)
!.mvn/wrapper/maven-wrapper.jar

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment & Secrets
*.env
*.p12
*.keystore
*.jks

# Large Binaries
*.exe
*.msi
*.dmg
*.pkg
*.jar
!.mvn/**/*.jar

# H2 Database files
data/
*.db
*.trace.db

# Logs
*.log
logs/

# Node modules
node_modules/
