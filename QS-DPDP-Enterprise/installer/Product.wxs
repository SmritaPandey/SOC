<?xml version="1.0" encoding="utf-8"?>
<!--
    QS-DPDP Enterprise — WiX Installer Source
    Provides Install / Repair / Uninstall wizard experience
    Requires WiX Toolset v3.11+ (https://wixtoolset.org)
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*"
             Name="QS-DPDP Enterprise"
             Language="1033"
             Version="1.0.0.0"
             Manufacturer="QualitySync Technologies"
             UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

        <Package InstallerVersion="500"
                 Compressed="yes"
                 InstallScope="perMachine"
                 Description="Enterprise Compliance Operating System for DPDP Act 2023"
                 Comments="QS-DPDP Enterprise v1.0.0"
                 Manufacturer="QualitySync Technologies" />

        <!-- Major Upgrade: Removes older versions automatically -->
        <MajorUpgrade DowngradeErrorMessage="A newer version of QS-DPDP Enterprise is already installed." />

        <!-- Embed all files in the MSI -->
        <MediaTemplate EmbedCab="yes" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- DIRECTORY STRUCTURE                                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder">
                <Directory Id="INSTALLFOLDER" Name="QS-DPDP Enterprise">
                    <Directory Id="JRE_DIR" Name="runtime" />
                </Directory>
            </Directory>

            <!-- Start Menu -->
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="QS-DPDP Enterprise" />
            </Directory>

            <!-- Desktop Shortcut -->
            <Directory Id="DesktopFolder" Name="Desktop" />
        </Directory>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- APPLICATION FILES                                          -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="MainJAR" Guid="B1C2D3E4-F5A6-7890-BCDE-123456789ABC">
                <File Id="AppJAR"
                      Source="$(var.TargetDir)\qs-dpdp-enterprise-1.0.0.jar"
                      KeyPath="yes" />
            </Component>

            <Component Id="LaunchScript" Guid="C2D3E4F5-A6B7-8901-CDEF-23456789ABCD">
                <File Id="LaunchBat"
                      Source="$(var.InstallerDir)\launch.bat"
                      KeyPath="yes" />
            </Component>
        </ComponentGroup>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SHORTCUTS                                                  -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="StartMenuShortcut" Guid="D3E4F5A6-B7C8-9012-DEFA-3456789ABCDE">
                <Shortcut Id="AppStartMenuShortcut"
                          Name="QS-DPDP Enterprise"
                          Description="DPDP Act 2023 Compliance Platform"
                          Target="[INSTALLFOLDER]launch.bat"
                          WorkingDirectory="INSTALLFOLDER"
                          Icon="AppIcon.ico" />
                <Shortcut Id="UninstallShortcut"
                          Name="Uninstall QS-DPDP Enterprise"
                          Description="Uninstalls QS-DPDP Enterprise"
                          Target="[System64Folder]msiexec.exe"
                          Arguments="/x [ProductCode]" />
                <RemoveFolder Id="CleanStartMenu" On="uninstall" />
                <RegistryValue Root="HKCU"
                               Key="Software\QualitySync\QS-DPDP Enterprise"
                               Name="installed" Type="integer" Value="1"
                               KeyPath="yes" />
            </Component>
        </DirectoryRef>

        <DirectoryRef Id="DesktopFolder">
            <Component Id="DesktopShortcut" Guid="E4F5A6B7-C8D9-0123-EFAB-456789ABCDEF">
                <Shortcut Id="AppDesktopShortcut"
                          Name="QS-DPDP Enterprise"
                          Description="DPDP Act 2023 Compliance Platform"
                          Target="[INSTALLFOLDER]launch.bat"
                          WorkingDirectory="INSTALLFOLDER"
                          Icon="AppIcon.ico" />
                <RegistryValue Root="HKCU"
                               Key="Software\QualitySync\QS-DPDP Enterprise"
                               Name="desktopShortcut" Type="integer" Value="1"
                               KeyPath="yes" />
            </Component>
        </DirectoryRef>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ICON                                                       -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Icon Id="AppIcon.ico" SourceFile="$(var.InstallerDir)\app-icon.ico" />
        <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
        <Property Id="ARPHELPLINK" Value="https://qualitysync.com" />
        <Property Id="ARPURLINFOABOUT" Value="https://qualitysync.com/qsdpdp" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- FEATURES                                                   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Feature Id="MainApplication" Title="QS-DPDP Enterprise" Level="1"
                 Description="Core compliance operating system"
                 ConfigurableDirectory="INSTALLFOLDER"
                 AllowAdvertise="no" Absent="disallow">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentRef Id="StartMenuShortcut" />
            <ComponentRef Id="DesktopShortcut" />
        </Feature>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- UI — WixUI_InstallDir with Repair/Uninstall/Modify         -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <UIRef Id="WixUI_InstallDir" />
        <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

        <!-- License Agreement (RTF) -->
        <WixVariable Id="WixUILicenseRtf" Value="$(var.InstallerDir)\License.rtf" />

        <!-- Banner and background images (optional) -->
        <!-- <WixVariable Id="WixUIBannerBmp" Value="$(var.InstallerDir)\banner.bmp" /> -->
        <!-- <WixVariable Id="WixUIDialogBmp" Value="$(var.InstallerDir)\dialog.bmp" /> -->
    </Product>
</Wix>
