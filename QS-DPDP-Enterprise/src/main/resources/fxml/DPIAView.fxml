<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1"
      styleClass="module-view" spacing="15">
    
    <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="DPIA Assessment" styleClass="page-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="➕ New DPIA" styleClass="action-button" />
        <Button text="📊 Export" styleClass="secondary-button" />
    </HBox>
    
    <Label text="Data Protection Impact Assessment under DPDP Act 2023" styleClass="page-subtitle" />
    
    <!-- Statistics Cards -->
    <HBox spacing="15" styleClass="stats-row">
        <VBox styleClass="stat-card stat-blue" HBox.hgrow="ALWAYS">
            <Label text="Total DPIAs" styleClass="stat-label" />
            <Label fx:id="totalDPIAsLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-green" HBox.hgrow="ALWAYS">
            <Label text="Approved" styleClass="stat-label" />
            <Label fx:id="approvedDPIAsLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-yellow" HBox.hgrow="ALWAYS">
            <Label text="Pending" styleClass="stat-label" />
            <Label fx:id="pendingDPIAsLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-red" HBox.hgrow="ALWAYS">
            <Label text="High Risk" styleClass="stat-label" />
            <Label fx:id="highRiskDPIAsLabel" text="--" styleClass="stat-value" />
        </VBox>
    </HBox>
    
    <!-- Risk Distribution -->
    <HBox spacing="10" styleClass="risk-breakdown">
        <Label text="Risk Distribution:" styleClass="breakdown-label" />
        <Label text="Low: 12" styleClass="badge badge-success" />
        <Label text="Medium: 8" styleClass="badge badge-warning" />
        <Label text="High: 5" styleClass="badge badge-danger" />
        <Label text="Critical: 1" styleClass="badge badge-critical" />
    </HBox>
    
    <!-- Filters -->
    <HBox spacing="10" styleClass="filter-bar">
        <Label text="Filter:" />
        <ComboBox fx:id="riskFilter" promptText="Risk Level" prefWidth="120" />
        <ComboBox fx:id="statusFilter" promptText="Status" prefWidth="120" />
        <TextField fx:id="searchField" promptText="Search by title..." prefWidth="200" />
        <Button text="🔍 Search" styleClass="secondary-button" />
    </HBox>
    
    <!-- Data Table -->
    <TableView fx:id="dpiasTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn text="Reference" prefWidth="100" />
            <TableColumn text="Title" prefWidth="200" />
            <TableColumn text="Activity" prefWidth="150" />
            <TableColumn text="Risk Level" prefWidth="100" />
            <TableColumn text="Status" prefWidth="100" />
            <TableColumn text="Review Date" prefWidth="120" />
            <TableColumn text="Actions" prefWidth="120" />
        </columns>
    </TableView>
    
    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="10" styleClass="pagination">
        <Button text="◀ Previous" styleClass="nav-btn" />
        <Label text="Page 1 of 3" />
        <Button text="Next ▶" styleClass="nav-btn" />
    </HBox>
    
</VBox>
