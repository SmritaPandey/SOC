<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="mainBorderPane" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.qsdpdp.ui.MainController"
            styleClass="main-container">
    
    <!-- Top Menu Bar -->
    <top>
        <VBox styleClass="header">
            <MenuBar styleClass="menu-bar">
                <Menu text="File">
                    <MenuItem text="Export Report" />
                    <MenuItem text="Backup Database" />
                    <SeparatorMenuItem />
                    <MenuItem text="Exit" />
                </Menu>
                <Menu text="View">
                    <MenuItem text="Dashboard" onAction="#onDashboardClick" />
                    <MenuItem text="Refresh" onAction="#onRefreshClick" />
                </Menu>
                <Menu text="Tools">
                    <MenuItem text="Compliance Audit" />
                    <MenuItem text="Generate Report" />
                    <MenuItem text="Settings" onAction="#onSettingsClick" />
                </Menu>
                <Menu text="Help">
                    <MenuItem text="User Guide" />
                    <MenuItem text="About" />
                </Menu>
            </MenuBar>
            
            <!-- Toolbar -->
            <ToolBar styleClass="toolbar">
                <Button text="🏠 Dashboard" onAction="#onDashboardClick" styleClass="nav-button" />
                <Separator orientation="VERTICAL" />
                <Button text="📝 Consents" onAction="#onConsentClick" styleClass="nav-button" />
                <Button text="🚨 Breaches" onAction="#onBreachClick" styleClass="nav-button" />
                <Button text="📋 Rights" onAction="#onRightsClick" styleClass="nav-button" />
                <Button text="📊 DPIAs" onAction="#onDPIAClick" styleClass="nav-button" />
                <Button text="📜 Policies" onAction="#onPolicyClick" styleClass="nav-button" />
                <Separator orientation="VERTICAL" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="complianceScoreLabel" text="--%" styleClass="compliance-score" />
                <Button text="🔄 Refresh" onAction="#onRefreshClick" styleClass="refresh-button" />
            </ToolBar>
        </VBox>
    </top>
    
    <!-- Left Navigation -->
    <left>
        <VBox fx:id="sideNav" styleClass="side-nav" prefWidth="200">
            <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
            
            <Label text="MODULES" styleClass="nav-header" />
            
            <Button text="📊 Dashboard" onAction="#onDashboardClick" 
                    styleClass="side-nav-button" maxWidth="Infinity" />
            <Button text="✅ Consent Management" onAction="#onConsentClick" 
                    styleClass="side-nav-button" maxWidth="Infinity" />
            <Button text="🚨 Breach Management" onAction="#onBreachClick" 
                    styleClass="side-nav-button" maxWidth="Infinity" />
            <Button text="📋 Rights Requests" onAction="#onRightsClick" 
                    styleClass="side-nav-button" maxWidth="Infinity" />
            <Button text="📊 DPIA Assessment" onAction="#onDPIAClick" 
                    styleClass="side-nav-button" maxWidth="Infinity" />
            <Button text="📜 Policy Management" onAction="#onPolicyClick" 
                    styleClass="side-nav-button" maxWidth="Infinity" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Label text="SETTINGS" styleClass="nav-header" />
            <Button text="⚙️ Configuration" onAction="#onSettingsClick" 
                    styleClass="side-nav-button" maxWidth="Infinity" />
        </VBox>
    </left>
    
    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane">
            <!-- Dashboard View (Default) -->
            <ScrollPane fitToWidth="true" styleClass="scroll-pane">
                <VBox spacing="20" styleClass="dashboard">
                    <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>
                    
                    <!-- Header -->
                    <Label text="Compliance Dashboard" styleClass="page-title" />
                    <Label text="DPDP Act 2023 - Enterprise Compliance Status" styleClass="page-subtitle" />
                    
                    <!-- KPI Cards -->
                    <HBox spacing="20" styleClass="kpi-row">
                        <VBox styleClass="kpi-card kpi-blue" HBox.hgrow="ALWAYS">
                            <Label text="Total Consents" styleClass="kpi-label" />
                            <Label fx:id="totalConsentsLabel" text="--" styleClass="kpi-value" />
                            <Label text="Active consent records" styleClass="kpi-sublabel" />
                        </VBox>
                        
                        <VBox styleClass="kpi-card kpi-red" HBox.hgrow="ALWAYS">
                            <Label text="Active Breaches" styleClass="kpi-label" />
                            <Label fx:id="activeBreachesLabel" text="--" styleClass="kpi-value" />
                            <Label text="Requiring attention" styleClass="kpi-sublabel" />
                        </VBox>
                        
                        <VBox styleClass="kpi-card kpi-yellow" HBox.hgrow="ALWAYS">
                            <Label text="Pending Requests" styleClass="kpi-label" />
                            <Label fx:id="pendingRequestsLabel" text="--" styleClass="kpi-value" />
                            <Label text="DSR within 30 days" styleClass="kpi-sublabel" />
                        </VBox>
                        
                        <VBox styleClass="kpi-card kpi-green" HBox.hgrow="ALWAYS">
                            <Label text="Active Policies" styleClass="kpi-label" />
                            <Label fx:id="activePoliciesLabel" text="--" styleClass="kpi-value" />
                            <Label text="Approved and effective" styleClass="kpi-sublabel" />
                        </VBox>
                    </HBox>
                    
                    <!-- Charts Row -->
                    <HBox spacing="20">
                        <VBox styleClass="chart-card" HBox.hgrow="ALWAYS">
                            <Label text="Compliance Overview" styleClass="chart-title" />
                            <PieChart fx:id="complianceChart" prefHeight="300" legendSide="BOTTOM" />
                        </VBox>
                        
                        <VBox styleClass="chart-card" HBox.hgrow="ALWAYS">
                            <Label text="Module Scores" styleClass="chart-title" />
                            <BarChart fx:id="moduleScoresChart" prefHeight="300">
                                <xAxis><CategoryAxis label="Module" /></xAxis>
                                <yAxis><NumberAxis label="Score %" /></yAxis>
                            </BarChart>
                        </VBox>
                    </HBox>
                    
                    <!-- Quick Actions -->
                    <VBox styleClass="quick-actions-card" spacing="10">
                        <Label text="Quick Actions" styleClass="section-title" />
                        <HBox spacing="10">
                            <Button text="➕ Record Consent" styleClass="action-button" />
                            <Button text="🚨 Report Breach" styleClass="action-button" />
                            <Button text="📋 New DSR Request" styleClass="action-button" />
                            <Button text="📊 Start DPIA" styleClass="action-button" />
                            <Button text="📄 Generate Report" styleClass="action-button" />
                        </HBox>
                    </VBox>
                    
                </VBox>
            </ScrollPane>
        </StackPane>
    </center>
    
    <!-- Bottom Status Bar -->
    <bottom>
        <HBox styleClass="status-bar" spacing="20">
            <padding><Insets top="5" right="10" bottom="5" left="10" /></padding>
            <Label fx:id="statusLabel" text="Ready" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="DPDP Act 2023 Compliant" styleClass="status-compliance" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="userLabel" text="System User" />
            <Label text="v1.0.0" />
        </HBox>
    </bottom>
    
</BorderPane>
