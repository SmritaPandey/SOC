<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.qsdpdp.ui.PIIScannerController"
            styleClass="module-view">
    
    <!-- Header -->
    <top>
        <VBox spacing="10" styleClass="module-header">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="🔍 QS-PII Scanner" styleClass="module-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⟳ Refresh" onAction="#onRefresh" styleClass="toolbar-button"/>
                <Button text="📊 Export Report" onAction="#onExportReport" styleClass="toolbar-button"/>
            </HBox>
            
            <Label text="Data Discovery &amp; PII Detection - DPDP Act 2023 Compliant" 
                   styleClass="module-subtitle"/>
        </VBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="15" styleClass="module-content">
            <padding><Insets top="15" right="20" bottom="20" left="20"/></padding>
            
            <!-- Scan Controls Panel -->
            <TitledPane text="📂 Scan Controls" expanded="true" collapsible="false">
                <VBox spacing="15">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                    
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="Scan Type:" styleClass="form-label"/>
                        <ComboBox fx:id="scanTypeCombo" promptText="Select scan type" prefWidth="200">
                        </ComboBox>
                        
                        <Label text="Source:" styleClass="form-label"/>
                        <TextField fx:id="sourceField" promptText="Enter path or text" 
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="Browse..." onAction="#onBrowse" styleClass="secondary-button"/>
                    </HBox>
                    
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <CheckBox fx:id="recursiveCheck" text="Recursive scan" selected="true"/>
                        <CheckBox fx:id="includeOfficeCheck" text="Include Office files" selected="false"/>
                        <CheckBox fx:id="sensitiveOnlyCheck" text="Sensitive PII only" selected="false"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="🔎 Start Scan" onAction="#onStartScan" 
                                styleClass="primary-button" prefWidth="150"/>
                    </HBox>
                    
                    <!-- Progress -->
                    <HBox spacing="10" alignment="CENTER_LEFT" fx:id="progressBox" visible="false">
                        <ProgressBar fx:id="scanProgress" prefWidth="300"/>
                        <Label fx:id="progressLabel" text="Scanning..."/>
                        <Button text="Cancel" onAction="#onCancelScan" styleClass="danger-button"/>
                    </HBox>
                </VBox>
            </TitledPane>
            
            <!-- Statistics Dashboard -->
            <HBox spacing="15">
                <!-- KPI Cards -->
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label text="Total Scans" styleClass="kpi-label"/>
                    <Label fx:id="totalScansLabel" text="0" styleClass="kpi-value"/>
                </VBox>
                
                <VBox styleClass="kpi-card kpi-critical" HBox.hgrow="ALWAYS">
                    <Label text="Critical Findings" styleClass="kpi-label"/>
                    <Label fx:id="criticalLabel" text="0" styleClass="kpi-value"/>
                </VBox>
                
                <VBox styleClass="kpi-card kpi-warning" HBox.hgrow="ALWAYS">
                    <Label text="Active Findings" styleClass="kpi-label"/>
                    <Label fx:id="activeFindingsLabel" text="0" styleClass="kpi-value"/>
                </VBox>
                
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label text="Affected Sources" styleClass="kpi-label"/>
                    <Label fx:id="affectedSourcesLabel" text="0" styleClass="kpi-value"/>
                </VBox>
            </HBox>
            
            <!-- Results Panel -->
            <SplitPane dividerPositions="0.65" VBox.vgrow="ALWAYS">
                
                <!-- Findings Table -->
                <TitledPane text="📋 PII Findings" collapsible="false">
                    <VBox spacing="10">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                        
                        <!-- Filters -->
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Filter:"/>
                            <ComboBox fx:id="riskFilterCombo" promptText="Risk Level" prefWidth="120"/>
                            <ComboBox fx:id="typeFilterCombo" promptText="PII Type" prefWidth="150"/>
                            <TextField fx:id="searchField" promptText="Search..." prefWidth="200"/>
                            <Button text="Clear" onAction="#onClearFilters" styleClass="secondary-button"/>
                        </HBox>
                        
                        <!-- Table -->
                        <TableView fx:id="findingsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="riskColumn" text="Risk" prefWidth="80"/>
                                <TableColumn fx:id="typeColumn" text="PII Type" prefWidth="120"/>
                                <TableColumn fx:id="maskedColumn" text="Masked Value" prefWidth="180"/>
                                <TableColumn fx:id="sourceColumn" text="Source" prefWidth="200"/>
                                <TableColumn fx:id="lineColumn" text="Line" prefWidth="60"/>
                                <TableColumn fx:id="confidenceColumn" text="Confidence" prefWidth="90"/>
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100"/>
                            </columns>
                            <placeholder>
                                <Label text="No PII findings. Run a scan to detect personal data."/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </TitledPane>
                
                <!-- Right Panel: Charts and Details -->
                <VBox spacing="15">
                    <!-- PII Type Distribution Chart -->
                    <TitledPane text="📊 PII Distribution" collapsible="false" VBox.vgrow="ALWAYS">
                        <PieChart fx:id="piiTypeChart" legendVisible="true" 
                                  title="Findings by PII Type"/>
                    </TitledPane>
                    
                    <!-- Finding Details -->
                    <TitledPane text="📝 Finding Details" collapsible="false" VBox.vgrow="ALWAYS">
                        <VBox spacing="10" fx:id="detailsPane">
                            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                            
                            <GridPane hgap="10" vgap="8">
                                <Label text="Type:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="detail-label"/>
                                <Label fx:id="detailType" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                
                                <Label text="Masked Value:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="detail-label"/>
                                <Label fx:id="detailMasked" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                
                                <Label text="Risk Level:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="detail-label"/>
                                <Label fx:id="detailRisk" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                
                                <Label text="Source:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="detail-label"/>
                                <Label fx:id="detailSource" GridPane.rowIndex="3" GridPane.columnIndex="1" wrapText="true"/>
                                
                                <Label text="DPDP Section:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="detail-label"/>
                                <Label fx:id="detailDPDP" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                
                                <Label text="Context:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="detail-label"/>
                                <TextArea fx:id="detailContext" GridPane.rowIndex="5" GridPane.columnIndex="1" 
                                          prefRowCount="3" editable="false" wrapText="true"/>
                            </GridPane>
                            
                            <HBox spacing="10" alignment="CENTER">
                                <Button text="Mark Remediated" onAction="#onMarkRemediated" 
                                        styleClass="success-button"/>
                                <Button text="False Positive" onAction="#onMarkFalsePositive" 
                                        styleClass="warning-button"/>
                            </HBox>
                        </VBox>
                    </TitledPane>
                </VBox>
            </SplitPane>
        </VBox>
    </center>
    
    <!-- Status Bar -->
    <bottom>
        <HBox styleClass="status-bar" spacing="20" alignment="CENTER_LEFT">
            <padding><Insets top="8" right="15" bottom="8" left="15"/></padding>
            <Label fx:id="statusLabel" text="Ready"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lastScanLabel" text="Last Scan: Never"/>
        </HBox>
    </bottom>
</BorderPane>
