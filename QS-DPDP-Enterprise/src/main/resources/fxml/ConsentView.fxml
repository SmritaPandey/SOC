<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1"
      styleClass="module-view" spacing="10">
    
    <padding><Insets top="15" right="20" bottom="15" left="20" /></padding>
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Consent Management" styleClass="page-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="➕ New Consent" styleClass="action-button" />
        <Button text="📊 Export" styleClass="secondary-button" />
    </HBox>
    
    <Label text="DPDP Act 2023 — Consent Lifecycle, Guardian, Audit Trail, Analytics &amp; Sector Templates" styleClass="page-subtitle" />
    
    <!-- Statistics Cards (Enhanced) -->
    <HBox spacing="10" styleClass="stats-row">
        <VBox styleClass="stat-card stat-blue" HBox.hgrow="ALWAYS">
            <Label text="Total Consents" styleClass="stat-label" />
            <Label fx:id="totalConsentsLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-green" HBox.hgrow="ALWAYS">
            <Label text="Active" styleClass="stat-label" />
            <Label fx:id="activeConsentsLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-yellow" HBox.hgrow="ALWAYS">
            <Label text="Expiring Soon" styleClass="stat-label" />
            <Label fx:id="expiringConsentsLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-red" HBox.hgrow="ALWAYS">
            <Label text="Withdrawn" styleClass="stat-label" />
            <Label fx:id="withdrawnConsentsLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-purple" HBox.hgrow="ALWAYS">
            <Label text="Compliance Score" styleClass="stat-label" />
            <Label fx:id="complianceScoreLabel" text="--%" styleClass="stat-value" />
        </VBox>
    </HBox>
    
    <!-- Tabbed Content -->
    <TabPane fx:id="consentTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        
        <!-- Tab 1: Consent Records -->
        <Tab text="📋 Consent Records">
            <VBox spacing="10">
                <padding><Insets top="10" right="5" bottom="5" left="5" /></padding>
                <HBox spacing="10" styleClass="filter-bar">
                    <ComboBox fx:id="statusFilter" promptText="Status" prefWidth="140" />
                    <ComboBox fx:id="purposeFilter" promptText="Purpose" prefWidth="200" />
                    <TextField fx:id="searchField" promptText="Search by principal..." prefWidth="220" />
                    <Button text="🔍 Search" styleClass="secondary-button" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="🔄 Refresh" styleClass="secondary-button" />
                </HBox>
                <TableView fx:id="consentsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                    <columns>
                        <TableColumn text="ID" prefWidth="80" />
                        <TableColumn text="Principal" prefWidth="160" />
                        <TableColumn text="Purpose" prefWidth="180" />
                        <TableColumn text="Status" prefWidth="90" />
                        <TableColumn text="Language" prefWidth="70" />
                        <TableColumn text="Collected" prefWidth="130" />
                        <TableColumn text="Expires" prefWidth="130" />
                        <TableColumn text="Actions" prefWidth="120" />
                    </columns>
                </TableView>
                <HBox alignment="CENTER" spacing="10" styleClass="pagination">
                    <Button text="◀ Previous" styleClass="nav-btn" />
                    <Label fx:id="consentPageLabel" text="Page 1 of 1" />
                    <Button text="Next ▶" styleClass="nav-btn" />
                </HBox>
            </VBox>
        </Tab>
        
        <!-- Tab 2: Guardian Consent (DPDP S.9) -->
        <Tab text="👶 Guardian Consent">
            <VBox spacing="10">
                <padding><Insets top="10" right="5" bottom="5" left="5" /></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Guardian Consent Records (DPDP Act Section 9, Rule 11)" styleClass="section-header" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="➕ New Guardian Consent" styleClass="action-button" />
                </HBox>
                <HBox spacing="10" styleClass="stats-row">
                    <VBox styleClass="stat-card stat-blue" HBox.hgrow="ALWAYS">
                        <Label text="Total" styleClass="stat-label" />
                        <Label fx:id="guardianTotalLabel" text="--" styleClass="stat-value" />
                    </VBox>
                    <VBox styleClass="stat-card stat-yellow" HBox.hgrow="ALWAYS">
                        <Label text="Pending KYC" styleClass="stat-label" />
                        <Label fx:id="guardianPendingLabel" text="--" styleClass="stat-value" />
                    </VBox>
                    <VBox styleClass="stat-card stat-green" HBox.hgrow="ALWAYS">
                        <Label text="Verified" styleClass="stat-label" />
                        <Label fx:id="guardianVerifiedLabel" text="--" styleClass="stat-value" />
                    </VBox>
                </HBox>
                <TableView fx:id="guardianTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                    <columns>
                        <TableColumn text="Child Name" prefWidth="140" />
                        <TableColumn text="Age" prefWidth="50" />
                        <TableColumn text="Guardian" prefWidth="140" />
                        <TableColumn text="Relationship" prefWidth="100" />
                        <TableColumn text="ID Type" prefWidth="80" />
                        <TableColumn text="KYC Status" prefWidth="100" />
                        <TableColumn text="Disability" prefWidth="80" />
                        <TableColumn text="Status" prefWidth="90" />
                        <TableColumn text="Actions" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        
        <!-- Tab 3: Audit Trail -->
        <Tab text="🔗 Audit Trail">
            <VBox spacing="10">
                <padding><Insets top="10" right="5" bottom="5" left="5" /></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Hash-Chained Consent Audit Ledger" styleClass="section-header" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="chainStatusLabel" text="🔒 Chain Integrity: Verified" styleClass="chain-verified" />
                    <Button text="🔍 Verify Chain" styleClass="secondary-button" />
                </HBox>
                <TableView fx:id="auditTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                    <columns>
                        <TableColumn text="Block #" prefWidth="70" />
                        <TableColumn text="Action" prefWidth="160" />
                        <TableColumn text="Consent ID" prefWidth="140" />
                        <TableColumn text="Principal" prefWidth="120" />
                        <TableColumn text="Action By" prefWidth="120" />
                        <TableColumn text="Details" prefWidth="200" />
                        <TableColumn text="Hash" prefWidth="140" />
                        <TableColumn text="Prev Hash" prefWidth="140" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        
        <!-- Tab 4: Sector Templates -->
        <Tab text="🏢 Sector Templates">
            <VBox spacing="10">
                <padding><Insets top="10" right="5" bottom="5" left="5" /></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Sector-Specific Purpose Templates" styleClass="section-header" />
                    <Region HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="sectorFilter" promptText="Filter by Sector" prefWidth="200" />
                </HBox>
                <TableView fx:id="sectorTemplatesTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                    <columns>
                        <TableColumn text="Sector" prefWidth="100" />
                        <TableColumn text="Code" prefWidth="120" />
                        <TableColumn text="Purpose Name" prefWidth="200" />
                        <TableColumn text="Legal Basis" prefWidth="120" />
                        <TableColumn text="Data Categories" prefWidth="180" />
                        <TableColumn text="Retention" prefWidth="100" />
                        <TableColumn text="Mandatory" prefWidth="80" />
                        <TableColumn text="Regulation" prefWidth="150" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        
        <!-- Tab 5: Consent Renewal -->
        <Tab text="🔄 Renewal">
            <VBox spacing="10">
                <padding><Insets top="10" right="5" bottom="5" left="5" /></padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Consent Renewal Management" styleClass="section-header" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="🔄 Renew Selected" styleClass="action-button" />
                    <Button text="🔄 Renew All Expiring" styleClass="secondary-button" />
                </HBox>
                <HBox spacing="10" styleClass="stats-row">
                    <VBox styleClass="stat-card stat-red" HBox.hgrow="ALWAYS">
                        <Label text="Expiring in 7 Days" styleClass="stat-label" />
                        <Label fx:id="expiring7Label" text="--" styleClass="stat-value" />
                    </VBox>
                    <VBox styleClass="stat-card stat-yellow" HBox.hgrow="ALWAYS">
                        <Label text="Expiring in 30 Days" styleClass="stat-label" />
                        <Label fx:id="expiring30Label" text="--" styleClass="stat-value" />
                    </VBox>
                    <VBox styleClass="stat-card stat-green" HBox.hgrow="ALWAYS">
                        <Label text="Renewed" styleClass="stat-label" />
                        <Label fx:id="renewedLabel" text="--" styleClass="stat-value" />
                    </VBox>
                </HBox>
                <TableView fx:id="renewalTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                    <columns>
                        <TableColumn text="Consent ID" prefWidth="120" />
                        <TableColumn text="Principal" prefWidth="160" />
                        <TableColumn text="Purpose" prefWidth="180" />
                        <TableColumn text="Expires At" prefWidth="150" />
                        <TableColumn text="Days Left" prefWidth="90" />
                        <TableColumn text="Actions" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        
        <!-- Tab 6: Analytics -->
        <Tab text="📊 Analytics">
            <VBox spacing="15">
                <padding><Insets top="10" right="5" bottom="5" left="5" /></padding>
                <Label text="Consent Compliance Analytics" styleClass="section-header" />
                <HBox spacing="15" styleClass="stats-row">
                    <VBox styleClass="stat-card stat-blue" HBox.hgrow="ALWAYS">
                        <Label text="Active Rate" styleClass="stat-label" />
                        <Label fx:id="activeRateLabel" text="--%" styleClass="stat-value" />
                    </VBox>
                    <VBox styleClass="stat-card stat-yellow" HBox.hgrow="ALWAYS">
                        <Label text="Withdrawal Rate" styleClass="stat-label" />
                        <Label fx:id="withdrawalRateLabel" text="--%" styleClass="stat-value" />
                    </VBox>
                    <VBox styleClass="stat-card stat-green" HBox.hgrow="ALWAYS">
                        <Label text="3rd Party Sharing" styleClass="stat-label" />
                        <Label fx:id="thirdPartyLabel" text="--%" styleClass="stat-value" />
                    </VBox>
                    <VBox styleClass="stat-card stat-purple" HBox.hgrow="ALWAYS">
                        <Label text="Cross-Border" styleClass="stat-label" />
                        <Label fx:id="crossBorderLabel" text="--%" styleClass="stat-value" />
                    </VBox>
                </HBox>
                <HBox spacing="15" VBox.vgrow="ALWAYS">
                    <VBox styleClass="chart-container" HBox.hgrow="ALWAYS">
                        <Label text="Consent Trends (30 Days)" styleClass="chart-title" />
                        <Label fx:id="consentTrendsPlaceholder" text="📈 Chart renders at runtime" styleClass="chart-placeholder" />
                    </VBox>
                    <VBox styleClass="chart-container" HBox.hgrow="ALWAYS">
                        <Label text="Language Distribution" styleClass="chart-title" />
                        <Label fx:id="languageDistPlaceholder" text="🥧 Chart renders at runtime" styleClass="chart-placeholder" />
                    </VBox>
                </HBox>
            </VBox>
        </Tab>
        
    </TabPane>
    
</VBox>
