<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1"
      styleClass="module-view" spacing="15">
    
    <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Breach Management" styleClass="page-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🚨 Report Breach" styleClass="danger-button" />
        <Button text="📊 Export" styleClass="secondary-button" />
    </HBox>
    
    <Label text="Data breach notification and response under DPDP Act Section 8" styleClass="page-subtitle" />
    
    <!-- Alert Banner for overdue breaches -->
    <HBox fx:id="overdueAlert" styleClass="alert-banner alert-danger" spacing="10" managed="false" visible="false">
        <Label text="⚠️" styleClass="alert-icon" />
        <Label fx:id="overdueAlertText" text="X breaches past 72-hour DPBI notification deadline!" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="View" styleClass="alert-button" />
    </HBox>
    
    <!-- Statistics Cards -->
    <HBox spacing="15" styleClass="stats-row">
        <VBox styleClass="stat-card stat-blue" HBox.hgrow="ALWAYS">
            <Label text="Total Breaches" styleClass="stat-label" />
            <Label fx:id="totalBreachesLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-red" HBox.hgrow="ALWAYS">
            <Label text="Open" styleClass="stat-label" />
            <Label fx:id="openBreachesLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-yellow" HBox.hgrow="ALWAYS">
            <Label text="Investigating" styleClass="stat-label" />
            <Label fx:id="investigatingLabel" text="--" styleClass="stat-value" />
        </VBox>
        <VBox styleClass="stat-card stat-green" HBox.hgrow="ALWAYS">
            <Label text="Resolved" styleClass="stat-label" />
            <Label fx:id="resolvedBreachesLabel" text="--" styleClass="stat-value" />
        </VBox>
    </HBox>
    
    <!-- Filters -->
    <HBox spacing="10" styleClass="filter-bar">
        <Label text="Filter:" />
        <ComboBox fx:id="severityFilter" promptText="Severity" prefWidth="120" />
        <ComboBox fx:id="statusFilter" promptText="Status" prefWidth="150" />
        <TextField fx:id="searchField" promptText="Search by reference..." prefWidth="200" />
        <Button text="🔍 Search" styleClass="secondary-button" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="72hr Compliance:" styleClass="metric-label" />
        <Label fx:id="complianceRateLabel" text="--%" styleClass="metric-value" />
    </HBox>
    
    <!-- Data Table -->
    <TableView fx:id="breachesTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn text="Reference" prefWidth="100" />
            <TableColumn text="Title" prefWidth="200" />
            <TableColumn text="Severity" prefWidth="80" />
            <TableColumn text="Status" prefWidth="100" />
            <TableColumn text="Detected" prefWidth="130" />
            <TableColumn text="DPBI Notified" prefWidth="100" />
            <TableColumn text="Affected" prefWidth="80" />
            <TableColumn text="Actions" prefWidth="120" />
        </columns>
    </TableView>
    
    <!-- Pagination -->
    <HBox alignment="CENTER" spacing="10" styleClass="pagination">
        <Button text="◀ Previous" styleClass="nav-btn" />
        <Label text="Page 1 of 5" />
        <Button text="Next ▶" styleClass="nav-btn" />
    </HBox>
    
</VBox>
