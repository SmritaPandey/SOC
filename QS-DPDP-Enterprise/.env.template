# ═══════════════════════════════════════════════════════════
# QS-DPDP Enterprise — Environment Variables Template
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════

# ── Application ──
QSDPDP_VERSION=3.0.0
QSDPDP_PORT=8443
TIMEZONE=Asia/Kolkata

# ── JVM Settings ──
JAVA_OPTS=-Xmx1g -Xms512m -XX:+UseG1GC -XX:+UseStringDeduplication -Dfile.encoding=UTF-8

# ── Redis (if using with-redis profile) ──
REDIS_PASSWORD=your-strong-redis-password-here

# ── Encryption ──
# Master encryption key for data-at-rest encryption
# Generate with: openssl rand -base64 32
QSDPDP_ENCRYPTION_KEY=CHANGE_ME_TO_A_RANDOM_32_BYTE_KEY

# ── Email (SMTP for notifications) ──
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_USERNAME=noreply@your-domain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=QS-DPDP Enterprise <noreply@your-domain.com>

# ── Logging ──
LOG_LEVEL=INFO
